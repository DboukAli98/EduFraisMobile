{
  "expo": {
    "name": "EduFrais",
    "slug": "EduFrais",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "edufrais",
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#4B49AC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edufrais.app",
      "infoPlist": {
        "NSFaceIDUsageDescription": "EduFrais uses Face ID to securely sign you in."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4B49AC"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.edufrais.app",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-localization",
      "expo-secure-store",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "EduFrais utilise Face ID pour vous connecter en toute sécurité."
        }
      ],
      [
        "onesignal-expo-plugin",
        {
          "mode": "development",
          "smallIcons": ["./assets/adaptive-icon.png"],
          "largeIcons": ["./assets/adaptive-icon.png"]
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "OneSignalNotificationServiceExtension",
                  "bundleIdentifier": "com.edufrais.app.OneSignalNotificationServiceExtension",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.com.edufrais.app.onesignal"
                    ]
                  }
                }
              ]
            }
          }
        },
        "projectId": "4029a34e-82d4-42c6-97a8-1edd7e6c0609"
      }
    }
  }
}
